<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.CuteKana" parent="android:Theme.Material.NoActionBar">
        <item name="android:statusBarColor">@color/dark_background</item>
        <item name="android:windowLightStatusBar">false</item>
        <item name="android:navigationBarColor">@color/dark_background</item>
        <item name="android:windowLightNavigationBar">false</item>
    </style>
    
    <!-- Splash Screen Theme for Night Mode -->
    <style name="Theme.CuteKana.Splash" parent="Theme.CuteKana">
        <item name="android:windowBackground">@drawable/splash_screen</item>
        <item name="android:statusBarColor">@color/sakura_pink</item>
        <item name="android:navigationBarColor">@color/sakura_pink</item>
    </style>
</resources>
